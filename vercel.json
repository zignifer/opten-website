{
  "redirects": [
    { "source": "/guides/gpt-image-2",    "destination": "/blog/gpt-image-2",    "permanent": true },
    { "source": "/en/guides/gpt-image-2", "destination": "/en/blog/gpt-image-2", "permanent": true },
    { "source": "/guides",                "destination": "/blog",                "permanent": true },
    { "source": "/en/guides",             "destination": "/en/blog",             "permanent": true }
  ],
  "rewrites": [
    { "source": "/account", "destination": "/index.html" },
    { "source": "/success", "destination": "/index.html" },
    { "source": "/dashboard/download-skill", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=(), payment=(self \"https://*.paddle.com\")" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/account/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/en/account/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/success/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/dashboard/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "functions": {
    "api/download-skill.ts": {
      "includeFiles": "api/_assets/**"
    }
  }
}
